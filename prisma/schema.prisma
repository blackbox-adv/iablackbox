// BLACKBOX V2 - Scalable schema for real-data product comparison platform
// Designed to scale to tens of thousands of products, multiple stores, languages,
// currencies, registered users, favorites, price history, price-drop alerts,
// and a future marketplace — without redesigning.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String    @id @default(cuid())
  name         String
  description  String
  category     String
  brand        String?
  images       String    @default("[]") // JSON array of image URLs
  features     String    @default("[]") // JSON array of feature strings
  specs        String    @default("{}") // JSON object of key specs

  // Sourcing (real data only)
  sourceUrl    String?   // original product URL the admin imported
  sourceStore  String?   // amazon | temu | falabella | other
  lastFetchedAt DateTime?

  // Visibility / curation
  isActive     Boolean   @default(true)
  isViral      Boolean   @default(false)
  isFeatured   Boolean   @default(false)

  // User contribution flow — products can be contributed by users (pending
  // approval) or created by admin. Approved products become public + SEO.
  contributionStatus String @default("approved") // pending | approved | rejected
  contributionSource String @default("admin")    // admin | user
  contributorIp   String?

  // SEO (AI-generated)
  slug         String?   @unique
  metaTitle    String?
  metaDescription String?

  // AI analysis (AI-generated, never invented — "No disponible" if absent)
  advantages   String    @default("[]") // JSON string[]
  disadvantages String   @default("[]") // JSON string[]
  useCases     String    @default("[]") // JSON string[]
  faqs         String    @default("[]") // JSON {q,a}[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  offers         Offer[]
  aiScores       AiScore[]
  clicks         Click[]
  priceHistory   PriceHistory[]
  scheduledOffers ScheduledOffer[]
  favorites      Favorite[]
  priceAlerts    PriceAlert[]
}

model Offer {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store         String   // amazon | temu | falabella | ...
  price         Float
  originalPrice Float?
  affiliateLink String
  shippingTime  String   @default("No disponible")
  shippingCost  Float    @default(0)
  availability  String   @default("in_stock") // in_stock | low_stock | out_of_stock | unknown
  rating        Float?   // 0-5
  reviewCount   Int      @default(0)
  currency      String   @default("PEN") // multi-currency ready
  updatedAt     DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([productId])
  @@index([store])
  @@index([price])
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  role        String   @default("user") // user | admin
  preferences String   @default("{}") // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clicks       Click[]
  favorites    Favorite[]
  priceAlerts  PriceAlert[]
}

model AiScore {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  score           Int      // 0-100
  classification  String   // excellent | good | regular | not_recommended
  reasoning       String
  recommendation  String?
  bestStore       String?
  summary         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([productId])
}

model Click {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  store     String?
  timestamp DateTime @default(now())

  @@index([productId])
}

model HomeSection {
  id       String @id @default(cuid())
  type     String // hero | offers | categories | ai_recommendations | comparator
  title    String
  subtitle String?
  isActive Boolean @default(true)
  order    Int
  config   String  @default("{}") // JSON config
}

model AffiliateLink {
  id        String  @id @default(cuid())
  store     String  @unique
  baseUrl   String
  tagParam  String?
  tagValue  String?
  isActive  Boolean @default(true)
}

model AiSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// ---- V2 scalability models ----

/// Price history per store, recorded on every refresh — powers price-drop charts & alerts.
model PriceHistory {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     String
  price     Float
  currency  String   @default("PEN")
  recordedAt DateTime @default(now())

  @@index([productId, store])
  @@index([recordedAt])
}

/// Admin-scheduled offers (programmed promotions) — start/end window + label.
model ScheduledOffer {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([isActive])
}

/// User favorites / wishlists — many-to-many with products.
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

/// Price-drop alerts — notify user when product price drops below target.
model PriceAlert {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  targetPrice Float
  isActive    Boolean  @default(true)
  triggeredAt DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([productId])
}

/// Search log — every search query is recorded. Used to detect trends
/// (popular searches with no matching products → admin creates landings).
model SearchLog {
  id           String   @id @default(cuid())
  query        String   // normalized lowercase
  count        Int      @default(1)
  hasResults   Boolean  @default(false)
  lastSearched DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([query])
  @@index([count])
  @@index([lastSearched])
}

/// SEO landing pages — generated by AI from trending searches or admin input.
/// Each landing is an indexable page at /guia/[slug] with Article + FAQ schema.
model LandingPage {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  metaTitle      String?
  metaDescription String?
  h1             String
  intro          String   // 1-2 paragraphs
  body           String   @default("[]") // JSON array of sections {type, heading, content}
  faqs           String   @default("[]") // JSON {q,a}[]
  relatedQuery   String?  // the search query that originated this landing
  status         String   @default("draft") // draft | published
  category       String?
  productIds     String   @default("[]") // JSON array of related product IDs
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([category])
}
